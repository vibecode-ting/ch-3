---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="relative overflow-hidden py-20 sm:py-32">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950"></div>
    <div class="absolute top-0 right-0 -z-10 translate-y-[-40%] translate-x-[20%] opacity-40">
      <div class="h-80 w-80 rounded-full bg-gradient-to-br from-blue-400 to-purple-500 blur-3xl"></div>
    </div>
    <div class="absolute bottom-0 left-0 -z-10 translate-y-[40%] translate-x-[-20%] opacity-40">
      <div class="h-80 w-80 rounded-full bg-gradient-to-br from-purple-400 to-blue-500 blur-3xl"></div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-5xl sm:text-6xl font-bold tracking-tight text-slate-900 dark:text-white mb-6 animate-fade-in">
        {t(lang, 'hero.heading')}
      </h2>
      <p class="text-xl text-slate-600 dark:text-slate-300 mb-8 animate-fade-in" style="animation-delay: 0.1s">
        {t(lang, 'hero.description')}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in" style="animation-delay: 0.2s">
        <button class="px-8 py-3 bg-gradient-to-r from-blue-500 to-purple-600 text-white font-semibold rounded-lg hover:shadow-lg hover:scale-105 transition-all duration-300">
          {t(lang, 'hero.cta')}
        </button>
        <button class="px-8 py-3 border-2 border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white font-semibold rounded-lg hover:bg-slate-50 dark:hover:bg-slate-900 transition-colors">
          Learn More
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
    opacity: 0;
  }
</style>
