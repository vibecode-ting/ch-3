---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/utils';

const lang = 'en';
const title = 'Documentation';
---

<Layout title={title} lang={lang}>
  <section class="py-20 sm:py-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <h1 class="text-5xl font-bold text-slate-900 dark:text-white mb-6">
          Documentation
        </h1>
        <p class="text-xl text-slate-600 dark:text-slate-300">
          Learn how to use Static Sites Builder to create amazing websites
        </p>
      </div>

      <!-- Documentation Sections -->
      <div class="space-y-12">
        <!-- Getting Started -->
        <div class="border-l-4 border-blue-500 pl-6">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">
            Getting Started
          </h2>
          <p class="text-slate-600 dark:text-slate-300 mb-4">
            Static Sites Builder makes it easy to create beautiful websites without coding. Follow these steps to get started:
          </p>
          <ol class="list-decimal list-inside space-y-2 text-slate-600 dark:text-slate-300">
            <li>Choose a template from our collection</li>
            <li>Customize colors, fonts, and layout</li>
            <li>Add your content and images</li>
            <li>Deploy to GitHub Pages with one click</li>
          </ol>
        </div>

        <!-- Templates -->
        <div class="border-l-4 border-purple-500 pl-6">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">
            Available Templates
          </h2>
          <p class="text-slate-600 dark:text-slate-300 mb-4">
            We offer a variety of professionally designed templates:
          </p>
          <ul class="space-y-2 text-slate-600 dark:text-slate-300">
            <li><strong>Portfolio:</strong> Showcase your work and projects</li>
            <li><strong>Business:</strong> Professional business website</li>
            <li><strong>Blog:</strong> Share your thoughts and ideas</li>
            <li><strong>Agency:</strong> Present your services</li>
            <li><strong>Shop:</strong> Sell your products online</li>
            <li><strong>Resume:</strong> Create an online CV</li>
          </ul>
        </div>

        <!-- Customization -->
        <div class="border-l-4 border-pink-500 pl-6">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">
            Customization
          </h2>
          <p class="text-slate-600 dark:text-slate-300 mb-4">
            Personalize your website with our easy-to-use customization tools:
          </p>
          <div class="bg-slate-50 dark:bg-slate-900 p-4 rounded-lg">
            <p class="text-slate-600 dark:text-slate-300 font-mono text-sm">
              Edit colors, fonts, spacing, and more directly in the builder
            </p>
          </div>
        </div>

        <!-- Deployment -->
        <div class="border-l-4 border-green-500 pl-6">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">
            Deployment
          </h2>
          <p class="text-slate-600 dark:text-slate-300 mb-4">
            Deploy your site to GitHub Pages in seconds:
          </p>
          <ol class="list-decimal list-inside space-y-2 text-slate-600 dark:text-slate-300">
            <li>Click the Deploy button</li>
            <li>Connect your GitHub account</li>
            <li>Your site goes live instantly</li>
            <li>Updates are automatic</li>
          </ol>
        </div>

        <!-- FAQ -->
        <div class="border-l-4 border-yellow-500 pl-6">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">
            Frequently Asked Questions
          </h2>
          <div class="space-y-4">
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-2">
                Is it really free?
              </h3>
              <p class="text-slate-600 dark:text-slate-300">
                Yes! Static Sites Builder is completely free. You only need a GitHub account.
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-2">
                Can I use my own domain?
              </h3>
              <p class="text-slate-600 dark:text-slate-300">
                Yes, you can connect your custom domain to your GitHub Pages site.
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-2">
                How do I update my site?
              </h3>
              <p class="text-slate-600 dark:text-slate-300">
                Simply edit your content in the builder and deploy again. It's that easy!
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Section -->
      <div class="mt-16 p-8 bg-gradient-to-r from-blue-500 to-purple-600 rounded-xl text-white text-center">
        <h2 class="text-2xl font-bold mb-4">Need Help?</h2>
        <p class="mb-6">
          Can't find what you're looking for? Contact our support team.
        </p>
        <button class="px-6 py-2 bg-white text-blue-600 font-semibold rounded-lg hover:shadow-lg transition-all">
          Get Support
        </button>
      </div>
    </div>
  </section>
</Layout>
